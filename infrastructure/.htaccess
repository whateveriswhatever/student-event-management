<IfModule mod_rewrite.c>
    RewriteEngine On

    # If the browser is requesting the root folder directly (empty string ^$), bypassinng directory checking and send it straight to the front router
    RewriteRule ^$ public/index.php [QSA,L]

    # For all other URLs, if it's an actual file or folder, serve it directly
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Otherwise, passing the clean virtual path into our front router script
    RewriteRule ^(.*)$ public/index.php [QSA,L]

</IfModule>

# Chặn truy cập trực tiếp vào các file và thư mục nhạy cảm
<FilesMatch "\.(env|sql|md|ini|log)$">
    Require all denied
</FilesMatch>

RewriteRule ^config/ - [F,L]
RewriteRule ^app/ - [F,L]

# NOTE (production): Đổi Access-Control-Allow-Origin trong index.php
# từ "*" sang domain cụ thể trước khi deploy lên môi trường thật
